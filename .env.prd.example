# Production environment.
# Copy this file to .env.prd for local production checks.
# In Railway/Vercel, enter these values in each service dashboard instead of committing them.

APP_ENV=prd
API_PORT=3000

# Frontend
VITE_API_BASE_URL=https://<your-railway-api-domain>
VITE_SUPABASE_URL=https://<your-prd-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-prd-supabase-anon-key>

# Supabase / Prisma
SUPABASE_URL=https://<your-prd-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-prd-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-prd-supabase-service-role-key>
DATABASE_URL=postgresql://postgres.<your-prd-project-ref>:<your-db-password>@<your-prd-pooler-host>:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:<your-db-password>@db.<your-prd-project-ref>.supabase.co:5432/postgres

# AI
# Choose one: mock, openai, gemini.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
