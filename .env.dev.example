# Local development environment.
# Copy this file to .env.dev and fill the values.

APP_ENV=dev
API_PORT=3000

# Frontend
VITE_API_BASE_URL=http://localhost:3000
VITE_SUPABASE_URL=https://<your-dev-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-dev-supabase-anon-key>

# Supabase / Prisma
SUPABASE_URL=https://<your-dev-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-dev-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-dev-supabase-service-role-key>
DATABASE_URL=postgresql://postgres.<your-dev-project-ref>:<your-db-password>@<your-dev-pooler-host>:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:<your-db-password>@db.<your-dev-project-ref>.supabase.co:5432/postgres

# AI
# Use mock until a real provider key is ready.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
