{
  "name": "kolma-ai-formulation-poc",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:web:dev": "npm --workspace apps/web run dev -- --mode dev",
    "dev:web:prd": "npm --workspace apps/web run dev -- --mode prd",
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev:api:dev": "APP_ENV=dev npm --workspace apps/api run start:dev",
    "dev:api:prd": "APP_ENV=prd npm --workspace apps/api run start:dev",
    "build:web": "npm --workspace apps/web run build",
    "build:web:dev": "npm --workspace apps/web run build -- --mode dev",
    "build:web:prd": "npm --workspace apps/web run build -- --mode prd",
    "build:api": "npm --workspace apps/api run build",
    "test:api": "npm --workspace apps/api run test",
    "test:api:e2e": "npm --workspace apps/api run test:e2e",
    "lint:web": "npm --workspace apps/web run lint",
    "lint:api": "npm --workspace apps/api run lint"
  }
}
